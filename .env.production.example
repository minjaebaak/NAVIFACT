# ============================================================
# NAVIFACT Production Environment Variables
# Copy to .env.production and fill in real values
# ============================================================

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.navifact.ai/api/v1
NEXT_PUBLIC_SITE_URL=https://navifact.ai

# --- Neo4j (managed: Neo4j Aura) ---
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- PostgreSQL (managed: Neon / Supabase / RDS) ---
POSTGRES_URL=postgresql+asyncpg://user:password@host:5432/navifact?sslmode=require

# --- Redis (managed: Upstash / ElastiCache) ---
REDIS_URL=rediss://default:password@host:6379

# --- Meilisearch (managed: Meilisearch Cloud) ---
MEILISEARCH_URL=https://ms-xxxx.meilisearch.io
MEILISEARCH_KEY=

# --- JWT ---
JWT_SECRET=

# --- Application ---
APP_NAME=NAVIFACT API
DEBUG=false
ALLOWED_ORIGINS=https://navifact.ai,https://www.navifact.ai
